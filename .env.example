# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agent_ops

# Used by api and worker containers (host = postgres service name in Docker)
DATABASE_URL=postgresql+asyncpg://agent:changeme@postgres:5432/agent_ops

# SQLAlchemy tuning
SQLALCHEMY_ECHO=false
POOL_SIZE=10
MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── FastAPI ────────────────────────────────────────────────────────────────────
WEBHOOK_PORT=8000
WEBHOOK_BASE_URL=https://your-domain.com

# ── Retell AI ──────────────────────────────────────────────────────────────────
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# ── Telnyx SIP ─────────────────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=
TELNYX_FROM_NUMBER=+91XXXXXXXXXX

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── OpenAI (GPT-4o Realtime via Retell) ───────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic (post-call analysis) ────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── n8n Automation ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://n8n:5678/webhook/post-call
N8N_WEBHOOK_SECRET=changeme
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Next.js Dashboard ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are embedded at build time — pass as Docker build args for production.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
